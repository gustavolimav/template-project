# Supabase (get values from `npx supabase status`)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API URL (use your machine's IP for physical device testing)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Sentry (optional — app works without it; errors won't be tracked)
# Get DSN from sentry.io → Project Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=

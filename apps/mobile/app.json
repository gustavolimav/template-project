{
  "expo": {
    "name": "App Template",
    "slug": "app-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "app-template",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.apptemplate",
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      ["expo-image-picker", {
        "photosPermission": "Permitir que $(BUNDLE_DISPLAY_NAME) acesse suas fotos para definir uma foto de perfil."
      }],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "REPLACE_WITH_SENTRY_ORG",
          "project": "REPLACE_WITH_SENTRY_PROJECT"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

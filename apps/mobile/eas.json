{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "REPLACE_WITH_CLOUD_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_CLOUD_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_API_URL": "REPLACE_WITH_VERCEL_URL",
        "SENTRY_AUTH_TOKEN": "REPLACE_WITH_SENTRY_AUTH_TOKEN"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "REPLACE_WITH_CLOUD_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_CLOUD_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_API_URL": "REPLACE_WITH_VERCEL_URL",
        "SENTRY_AUTH_TOKEN": "REPLACE_WITH_SENTRY_AUTH_TOKEN"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID",
        "ascAppId": "REPLACE_WITH_YOUR_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_YOUR_TEAM_ID"
      }
    }
  }
}

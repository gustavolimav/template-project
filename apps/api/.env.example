# ─── Supabase Auth (from Supabase Dashboard → Settings → API) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SECRET_KEY=

# ─── Postgres (from Supabase Dashboard → Settings → Database) ───────────────
POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_PRISMA_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_USER=postgres
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres

# ─── Admin migrations endpoint (/api/admin/migrations) ──────────────────────
# Uses POSTGRES_URL_NON_POOLING above (direct connection, required for DDL)
# Generate ADMIN_SECRET with: openssl rand -hex 32
ADMIN_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081

# ─── Sentry (optional) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

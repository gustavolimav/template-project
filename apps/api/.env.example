# Supabase connection (get values from `npx supabase status`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection for running migrations (DDL) via /api/admin/migrations
# Get from: Supabase Dashboard → Settings → Database → Connection string → Direct connection
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Secret key for /api/admin/* endpoints — generate with: openssl rand -hex 32
ADMIN_SECRET=

# CORS: comma-separated allowed origins for mobile app
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081

# Sentry (optional — app works without it; errors won't be tracked)
# Get DSN + auth token from sentry.io → Project Settings
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
